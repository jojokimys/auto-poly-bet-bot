generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Market {
  id          String           @id @default(cuid())
  conditionId String           @unique
  question    String
  slug        String
  endDate     String
  active      Boolean          @default(true)
  closed      Boolean          @default(false)
  liquidity   Float            @default(0)
  volume      Float            @default(0)
  image       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  snapshots   MarketSnapshot[]
  orders      Order[]
  outcomes    Outcome[]
}

model Outcome {
  id       String @id @default(cuid())
  marketId String
  name     String
  tokenId  String
  price    Float  @default(0)
  market   Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@unique([marketId, name])
}

model Order {
  id          String   @id @default(cuid())
  externalId  String?  @unique
  marketId    String
  tokenId     String
  side        String
  price       Float
  size        Float
  sizeMatched Float    @default(0)
  status      String   @default("OPEN")
  type        String   @default("LIMIT")
  outcome     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  market      Market   @relation(fields: [marketId], references: [id])
  trades      Trade[]
}

model Trade {
  id         String   @id @default(cuid())
  externalId String?  @unique
  orderId    String
  price      Float
  size       Float
  fee        Float    @default(0)
  matchTime  DateTime
  createdAt  DateTime @default(now())
  order      Order    @relation(fields: [orderId], references: [id])
}

model MarketSnapshot {
  id         String   @id @default(cuid())
  marketId   String
  yesPrice   Float
  noPrice    Float
  volume24hr Float    @default(0)
  spread     Float    @default(0)
  liquidity  Float    @default(0)
  snapshotAt DateTime @default(now())
  market     Market   @relation(fields: [marketId], references: [id])

  @@index([marketId, snapshotAt])
}

model BotProfile {
  id                   String   @id @default(cuid())
  name                 String
  privateKey           String
  funderAddress        String   @default("")
  signatureType        Int      @default(2)
  apiKey               String
  apiSecret            String
  apiPassphrase        String
  builderApiKey        String   @default("")
  builderApiSecret     String   @default("")
  builderApiPassphrase String   @default("")
  isActive             Boolean  @default(true)
  enabledStrategies    String   @default("[\"value-betting\"]")
  maxPortfolioExposure Float    @default(0.4)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model BotLog {
  id        String   @id @default(cuid())
  level     String
  event     String
  message   String
  data      String?
  createdAt DateTime @default(now())
  profileId String?

  @@index([createdAt])
  @@index([event])
  @@index([profileId])
}

model AiSession {
  id         String       @id @default(cuid())
  profileId  String
  startedAt  DateTime     @default(now())
  endedAt    DateTime?
  cycleCount Int          @default(0)
  totalPnl   Float        @default(0)
  summary    String?
  decisions  AiDecision[]

  @@index([profileId])
}

model AiDecision {
  id          String    @id @default(cuid())
  sessionId   String
  profileId   String
  type        String
  conditionId String?
  action      String?
  tokenId     String?
  outcome     String?
  price       Float?
  size        Float?
  reason      String
  confidence  Int
  result      String?
  pnl         Float?
  createdAt   DateTime  @default(now())
  strategy    String?
  session     AiSession @relation(fields: [sessionId], references: [id])

  @@index([profileId, createdAt])
  @@index([sessionId])
}

model AiLearning {
  id         String   @id @default(cuid())
  profileId  String
  category   String
  insight    String
  confidence Int
  source     String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([profileId, category])
}

model LpBlacklist {
  id          String   @id @default(cuid())
  conditionId String   @unique
  slug        String
  reason      String   @default("filled")
  createdAt   DateTime @default(now())

  @@index([conditionId])
}
